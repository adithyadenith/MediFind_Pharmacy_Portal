# Database (required - your Supabase connection string)
DATABASE_URL=postgresql://user:password@host:port/dbname

# Session secret (optional in dev - a default will be used if not set)
# CHANGE THIS IN PRODUCTION!
SESSION_SECRET=your-super-secret-key-here

# Resend email delivery for OTP
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=onboarding@resend.dev

# Ports (optional - defaults: API=3001, Frontend=5173)
# PORT=3001   # for api-server
# PORT=5173   # for medifind-admin

# Frontend API base URL (optional)
# Set this when the frontend is hosted separately from the backend.
# Example: VITE_API_BASE_URL=https://medifindpharmacyportal-production.up.railway.app
VITE_API_BASE_URL=
